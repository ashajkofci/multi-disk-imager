<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MultiDiskImager.ViewModels"
        xmlns:controls="using:MultiDiskImager.Controls"
        xmlns:loc="using:MultiDiskImager.Localization"
        x:Class="MultiDiskImager.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowTitle}"
        Icon="/Assets/AppIcon.png"
        Width="920" Height="760" MinWidth="760" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        DragDrop.AllowDrop="True"
        DragDrop.DragOver="OnDragOver" DragDrop.Drop="OnDrop"
        Closing="OnClosing">
  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="20" RowSpacing="12">
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
      <StackPanel>
        <TextBlock Text="bNovate Multi Disk Imager" FontSize="26" FontWeight="SemiBold" />
        <TextBlock Text="{loc:Tr Tagline}" Opacity="0.7" />
      </StackPanel>
      <Button Grid.Column="1" Content="{loc:Tr Settings}" Click="OnSettings" VerticalAlignment="Center" />
      <Button Grid.Column="2" Content="{loc:Tr About}" Click="OnAbout" VerticalAlignment="Center" />
    </Grid>

    <Border Grid.Row="1" Classes="card" Background="#1D4ED8" IsVisible="{Binding HasAvailableUpdate}">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Foreground="White" Text="{loc:Tr UpdateAvailable}" VerticalAlignment="Center" />
        <Button Grid.Column="1" Content="{loc:Tr ViewRelease}" Click="OnOpenUpdate" />
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="2">
      <StackPanel Spacing="12">
        <Border Classes="card">
          <StackPanel Spacing="8">
            <TextBlock Text="{loc:Tr RawImage}" FontSize="17" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBox Text="{Binding ImagePath}" PlaceholderText="{loc:Tr ImagePlaceholder}" />
              <Button Grid.Column="1" Content="{loc:Tr Browse}" Click="OnBrowse" />
            </Grid>
            <TextBlock Text="{loc:Tr NoMetadata}" FontSize="12" Opacity="0.65" />
          </StackPanel>
        </Border>

        <Border Classes="card">
          <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{loc:Tr Devices}" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center" />
                <ProgressBar Width="64" Height="4" IsIndeterminate="True" IsVisible="{Binding IsRefreshing}" />
              </StackPanel>
              <Button Grid.Column="1" Content="{loc:Tr Refresh}" Click="OnRefresh" IsEnabled="{Binding IsIdle}" />
            </Grid>
            <ItemsControl Grid.Row="1" ItemsSource="{Binding Devices}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:DeviceItemViewModel">
                  <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Padding="4,10">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                      <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
                      <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Model}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Details}" FontSize="12" Opacity="0.7" />
                      </StackPanel>
                      <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding Size}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                        <TextBlock Text="{Binding Id}" FontSize="12" Opacity="0.7" HorizontalAlignment="Right" />
                      </StackPanel>
                      <Button Grid.Column="3" Content="{loc:Tr Info}" Tag="{Binding}" Click="OnDeviceInfo" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Grid>
        </Border>

        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
          <Border Classes="card">
            <StackPanel Spacing="8">
              <TextBlock Text="{loc:Tr Options}" FontSize="17" FontWeight="SemiBold" />
              <CheckBox Content="{loc:Tr OnlyAllocated}" IsChecked="{Binding OnlyAllocated}" />
              <CheckBox Content="{loc:Tr VerifyAfter}" IsChecked="{Binding VerifyAfter}" />
            </StackPanel>
          </Border>
          <Border Grid.Column="1" Classes="card">
            <StackPanel Spacing="8">
              <TextBlock Text="{loc:Tr ImageChecksum}" FontSize="17" FontWeight="SemiBold" />
              <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                <ComboBox ItemsSource="{Binding ChecksumAlgorithms}" SelectedItem="{Binding ChecksumAlgorithm}" MinWidth="90" />
                <TextBox Grid.Column="1" Text="{Binding Checksum}" IsReadOnly="True" PlaceholderText="{loc:Tr Checksum}" />
                <Button Grid.Column="2" Content="{loc:Tr Calculate}" Click="OnChecksum" IsEnabled="{Binding IsIdle}" />
              </Grid>
            </StackPanel>
          </Border>
        </Grid>

        <Border Classes="card" IsVisible="{Binding IsBusy}">
          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="{Binding ProgressText}" />
              <Button Grid.Column="1" Classes="danger" Content="{loc:Tr Cancel}" Click="OnCancel" />
            </Grid>
            <ProgressBar Minimum="0" Maximum="100" Value="{Binding Progress}" Height="8" />
            <controls:SpeedGraph Samples="{Binding SpeedSamples}" Height="90" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="12">
      <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="6" Padding="10,7">
        <TextBlock Text="{Binding Status}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
      </Border>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button Content="{loc:Tr ReadDevice}" Click="OnRead" IsEnabled="{Binding IsIdle}" />
        <Button Classes="primary" Content="{loc:Tr WriteImage}" Click="OnWrite" IsEnabled="{Binding IsIdle}" />
        <Button Content="{loc:Tr Verify}" Click="OnVerify" IsEnabled="{Binding IsIdle}" />
        <Button Classes="danger" Content="{loc:Tr QuickWipe}" Click="OnWipe" IsEnabled="{Binding IsIdle}" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
